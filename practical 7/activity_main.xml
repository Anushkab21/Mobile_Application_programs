<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_x="0dp"
        android:layout_y="30dp"
        android:text="Progress Bar"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:background="#DDEEFF"
        android:padding="10dp"/>

    <!-- Deterministic -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="60dp"
        android:layout_y="120dp"
        android:text="Deterministic Progress Bar"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/button"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_x="125dp"
        android:layout_y="190dp"
        android:text="Start"/>

    <!-- Rating -->
    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="70dp"
        android:layout_y="280dp"/>

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="60dp"
        android:layout_y="360dp"
        android:text="Rating:"
        android:textSize="16sp"/>

    <!-- Non Deterministic -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="45dp"
        android:layout_y="430dp"
        android:text="Non-Deterministic Progress Bar"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <ProgressBar
        android:id="@+id/progressBar2"
        style="?android:attr/progressBarStyle"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_x="130dp"
        android:layout_y="500dp"/>

    <Button
        android:id="@+id/button2"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_x="120dp"
        android:layout_y="640dp"
        android:text="Download"
        android:onClick="download"/>

</AbsoluteLayout>