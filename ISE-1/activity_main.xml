<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    >


    <ImageView
        android:id="@+id/imageView"
        android:layout_width="108dp"
        android:layout_height="90dp"
        android:layout_x="16dp"
        android:layout_y="32dp"
        android:src="@drawable/img"
        tools:srcCompat="@drawable/img" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="266dp"
        android:layout_height="wrap_content"
        android:layout_x="136dp"
        android:layout_y="63dp"
        android:text="D.Y.Patil College of Engineering and Technolody"
        android:textSize="20dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="45dp"
        android:layout_y="151dp"
        android:text="Computer Science And Engineering "
        android:textSize="20dp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="129dp"
        android:layout_y="235dp"
        android:text="Welcome" />

</AbsoluteLayout>
